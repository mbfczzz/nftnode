# nftables 转发面板配置

[auth]
password = "admin123"
# password_hash = ""  # 首次运行时会自动将明文密码哈希化并填入此字段

[server]
port = 3456

[https]
enabled = false
cert_file = "./certificate/cert.pem"
key_file = "./certificate/private.key"

[nftables]
config_path = "/etc/nftables.conf"
rules_path = "/root/.nft-forward/rules.json"

[session]
# secret = ""  # 首次运行时会自动生成随机密钥

[metrics]
# token = ""   # 留空则自动生成，用于被控端暴露 API 的 Bearer Token

# 主控端填写各被控节点，被控端不需要此段
# [[nodes]]
# name  = "东京中转"
# url   = "https://1.2.3.4:3456"
# token = "xxx"
