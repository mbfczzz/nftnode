# Go build outputs
*.exe
*.out
web/nft_panel
web/web

# Release archives (distribute via GitHub Releases, not in repo)
web/*.tar.gz

# Go caches (created when GOCACHE/GOMODCACHE point into project dir)
.gocache/
.gomodcache/

# Go test cache
*.test

# Runtime/config files (generated on first run, contain secrets)
web/config.toml
!web/config.toml.example

# nftables rules data (server-side runtime data)
/root/.nft-forward/

# Editor / OS artefacts
.DS_Store
Thumbs.db
.vscode/
.idea/
